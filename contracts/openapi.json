{
  "components": {
    "schemas": {
      "ApiErrorResponse": {
        "properties": {
          "code": {
            "description": "Stable snake_case application error code.",
            "type": "string"
          },
          "details": {
            "description": "Optional structured error details.",
            "type": "object"
          },
          "message": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "requestId"
        ],
        "type": "object"
      },
      "CapabilityFlags": {
        "properties": {
          "aiArchiveEnabled": {
            "type": "boolean"
          },
          "attachmentsEnabled": {
            "type": "boolean"
          },
          "authMockEnabled": {
            "type": "boolean"
          },
          "desktopEnabled": {
            "type": "boolean"
          }
        },
        "required": [
          "authMockEnabled",
          "desktopEnabled",
          "aiArchiveEnabled",
          "attachmentsEnabled"
        ],
        "type": "object"
      },
      "MetaResponse": {
        "properties": {
          "appName": {
            "const": "Campus Agora",
            "type": "string"
          },
          "capabilities": {
            "$ref": "#/components/schemas/CapabilityFlags"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "appName",
          "version",
          "capabilities"
        ],
        "type": "object"
      },
      "ReadinessChecks": {
        "properties": {
          "postgres": {
            "enum": [
              "ok",
              "unavailable"
            ],
            "type": "string"
          }
        },
        "required": [
          "postgres"
        ],
        "type": "object"
      },
      "ReadinessResponse": {
        "properties": {
          "checks": {
            "$ref": "#/components/schemas/ReadinessChecks"
          },
          "status": {
            "enum": [
              "ready",
              "unready"
            ],
            "type": "string"
          }
        },
        "required": [
          "status",
          "checks"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Campus Agora API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/meta": {
      "get": {
        "operationId": "getMeta",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetaResponse"
                }
              }
            },
            "description": "Application metadata"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Unexpected server error"
          }
        },
        "security": [],
        "summary": "Application metadata and capability flags"
      }
    },
    "/healthz": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "text/plain": {
                "schema": {
                  "const": "ok",
                  "type": "string"
                }
              }
            },
            "description": "API process is alive"
          }
        },
        "security": [],
        "summary": "Health check"
      }
    },
    "/readyz": {
      "get": {
        "operationId": "getReadiness",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "API dependencies are ready"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "API dependencies are not ready"
          }
        },
        "security": [],
        "summary": "Readiness check"
      }
    }
  }
}
