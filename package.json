{
  "name": "campus-agora",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun --cwd apps/web dev",
    "dev:api": "cargo run -p campus_agora_api",
    "dev:desktop": "bun --cwd apps/desktop dev",
    "typecheck": "bun --cwd packages/api-client typecheck && bun --cwd apps/web typecheck",
    "lint": "bun --cwd apps/web lint",
    "lint:styles": "bun --cwd apps/web lint:styles",
    "test": "bun --cwd apps/web test && cargo test --workspace",
    "build": "bun --cwd packages/api-client build && bun --cwd apps/web build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
