# Local development defaults. Copy to .env for local use; do not commit .env.

SERVER_HOST=127.0.0.1
SERVER_PORT=8080
DATABASE_URL=postgres://campus_agora:campus_agora@127.0.0.1:5432/campus_agora
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
RUST_LOG=campus_agora_api=info,tower_http=info
REQUEST_BODY_LIMIT_BYTES=1048576

# M0.1 capability flags.
AUTH_MOCK_ENABLED=true
DESKTOP_ENABLED=true
AI_ARCHIVE_ENABLED=false
ATTACHMENTS_ENABLED=false

# Non-secret environment labels used by deployment and CI scripts.
APP_ENV=local
PUBLIC_WEB_BASE_URL=http://127.0.0.1:5173
PUBLIC_API_BASE_URL=http://127.0.0.1:8080
